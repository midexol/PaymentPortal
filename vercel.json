{
  "version": 2,
  "builds": [
    {
      "src": "payment-portal/app.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "payment-portal/public/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "payment-portal/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "payment-portal/app.js"
    }
  ]
}
